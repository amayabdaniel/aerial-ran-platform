# aerial-ran-platform — copy to .env and fill in values

# ──────── Postgres ────────
POSTGRES_USER=aerial_admin
POSTGRES_PASSWORD=aerial_dev_pass_change_me
POSTGRES_DB=aerial

# ──────── NATS (Jetstream) ────────
NATS_URL=nats://nats:4222
# Optional auth (dev: none)
NATS_USER=
NATS_PASSWORD=

# ──────── JWT ────────
JWT_SECRET=dev-secret-change-in-production-32ch
JWT_ISSUER=aerial-ran-platform
JWT_AUDIENCE=aerial-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ──────── HMAC request signing (optional) ────────
HMAC_SIGNING_KEY=
HMAC_SKEW=300s

# ──────── eSIM provider credentials (Phase 2) ────────
# Airalo Partners API — partners.airalo.com
AIRALO_CLIENT_ID=
AIRALO_CLIENT_SECRET=
AIRALO_BASE_URL=https://sandbox-partners-api.airalo.com
# EMnify (fallback)
EMNIFY_USERNAME=
EMNIFY_PASSWORD=
EMNIFY_BASE_URL=https://cdn.emnify.net/api

# ──────── Open5GS connection (Phase 0+) ────────
# WebUI exposed via k3d port-forward
OPEN5GS_WEBUI_URL=http://localhost:9999
# MongoDB used by Open5GS WebUI for subscriber CRUD
OPEN5GS_MONGO_URI=mongodb://open5gs-mongodb:27017/open5gs
# Default test PLMN (3GPP TS 23.003 reserved test network)
PLMN_MCC=999
PLMN_MNC=70

# ──────── Aerial / GPU (Phase 3) ────────
AERIAL_LICENSE_KEY=
DCGM_EXPORTER_URL=http://dcgm-exporter:9400

# ──────── FlexRIC xApp (Phase 1+) ────────
FLEXRIC_NEARRT_E42_ADDR=
FLEXRIC_NEARRT_E42_PORT=36422

# ──────── OpenTelemetry ────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev

# ──────── Service ports (host-bound for dev) ────────
# Internal only; nginx is the single entrypoint
IAM_PORT=8081
SUBSCRIBER_PORT=8082
ESIM_PORT=8083
PROVISION_PORT=8084
RAN_CTL_PORT=8085
BILLING_PORT=8086
MESSAGING_PORT=8087

# ──────── CORS ────────
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ──────── Mobile push (later) ────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_PATH=
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_PATH=
